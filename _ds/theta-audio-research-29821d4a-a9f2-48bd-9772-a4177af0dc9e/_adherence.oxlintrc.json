        "message": "<DataReadout> doesn't accept that prop. Declared props: items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:product|sub|tagline|mark|actions|style|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: product, sub, tagline, mark, actions, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Knob'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|display|size|bipolar|accent|style|key|ref|className|style|children)$/]",
        "message": "<Knob> doesn't accept that prop. Declared props: label, value, display, size, bipolar, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Knob'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<Knob> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|orientation|gr|label|accent|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: level, orientation, gr, label, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:vertical|horizontal)$/]",
        "message": "<Meter> orientation must be one of 'vertical' | 'horizontal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<Meter> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModulePanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|on|accent|toggle|onToggle|actions|children|style|key|ref|className|style|children)$/]",
        "message": "<ModulePanel> doesn't accept that prop. Declared props: title, on, accent, toggle, onToggle, actions, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModulePanel'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<ModulePanel> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillSlider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|display|accent|width|style|key|ref|className|style|children)$/]",
        "message": "<PillSlider> doesn't accept that prop. Declared props: label, value, display, accent, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PillSlider'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<PillSlider> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PluginHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:product|version|actions|style|key|ref|className|style|children)$/]",
        "message": "<PluginHeader> doesn't accept that prop. Declared props: product, version, actions, style."
