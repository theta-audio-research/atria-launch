        "selector": "JSXOpeningElement[name.name='ThetaProvider'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<ThetaProvider> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
