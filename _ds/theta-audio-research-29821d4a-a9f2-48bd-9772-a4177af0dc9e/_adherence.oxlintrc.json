{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": [
          {
            "element": "button",
            "message": "Use <Button> from the design system instead of <button>."
          },
          {
            "element": "select",
            "message": "Use <Select> from the design system instead of <select>."
          },
          {
            "element": "input",
            "message": "Use <TextField> from the design system instead of <input>."
          }
        ]
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/BrandLockup/**",
              "components/brand/ThetaLogo/**",
              "components/brand/ThetaWordmark/**",
              "components/controls/Button/**",
              "components/controls/Knob/**",
              "components/controls/PillSlider/**",
              "components/controls/SegmentedControl/**",
              "components/controls/Select/**",
              "components/controls/TextField/**",
              "components/controls/Toggle/**",
              "components/display/Badge/**",
              "components/display/DataReadout/**",
              "components/display/Meter/**",
              "components/display/ScopeScreen/**",
              "components/display/SpecTable/**",
              "components/foundations/AccentScope/**",
              "components/foundations/ThetaProvider/**",
              "components/marketing/Hero/**",
              "components/marketing/ProductCard/**",
              "components/structure/ModulePanel/**",
              "components/structure/PluginHeader/**",
              "components/structure/SectionHeading/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Montserrat|Rubik))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Montserrat, Rubik."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentScope'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|style|children|key|ref|className|style|children)$/]",
        "message": "<AccentScope> doesn't accept that prop. Declared props: accent, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccentScope'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<AccentScope> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|accent|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, accent, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid|version)$/]",
        "message": "<Badge> variant must be one of 'outline' | 'solid' | 'version'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<Badge> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandLockup'] > JSXAttribute > JSXIdentifier[name!=/^(?:product|sub|mark|size|style|key|ref|className|style|children)$/]",
        "message": "<BrandLockup> doesn't accept that prop. Declared props: product, sub, mark, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|accent|className|id|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, accent, className, id, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|primary|ghost)$/]",
        "message": "<Button> variant must be one of 'outline' | 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:gold|coral|teal|purple|blue|amber)$/]",
        "message": "<Button> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
