        "selector": "JSXOpeningElement[name.name='ThetaProvider'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:gold|void)$/]",
        "message": "<ThetaProvider> theme must be one of 'gold' | 'void'."
