        "message": "<SegmentedControl> accent must be one of 'gold' | 'coral' | 'teal' | 'purple' | 'blue' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|width|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|style|key|ref|className|style|children)$/]",
        "message": "<SpecTable> doesn't accept that prop. Declared props: rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|defaultValue|hint|multiline|onChange|width|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, placeholder, value, defaultValue, hint, multiline, onChange, width, style."
      },
