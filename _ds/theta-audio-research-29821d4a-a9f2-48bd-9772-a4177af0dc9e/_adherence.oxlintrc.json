        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|label|accent|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, label, accent, onChange, style."
