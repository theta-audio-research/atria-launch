        "selector": "JSXOpeningElement[name.name='ThetaProvider'] > JSXAttribute > JSXIdentifier[name!=/^(?:theme|accent|fullscreen|style|children|key|ref|className|style|children)$/]",
        "message": "<ThetaProvider> doesn't accept that prop. Declared props: theme, accent, fullscreen, style, children."
      },
